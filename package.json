{
  "name": "loglens",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:rust": "cd src-tauri && cargo test",
    "lint:js": "oxlint",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "format:rust": "cd src-tauri && cargo fmt --all",
    "lint": "pnpm lint:js && pnpm lint:rust",
    "test:large-regression": "vitest run src/lib/logs/parser.test.ts src/test/runtime-harness.test.tsx",
    "bench:large-session": "LOG_LENS_LARGE_BENCH=1 vitest run src/lib/logs/large-session.benchmark.test.ts",
    "check:runtime-smoke": "vitest run src/test/runtime-harness.test.tsx && cd src-tauri && cargo test allow_file_access",
    "check:harness": "node scripts/check-agent-harness.mjs",
    "check:agent-gc": "node scripts/check-agent-gc.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check": "pnpm lint && pnpm check:harness && pnpm check:agent-gc && pnpm test && pnpm build && pnpm check:bundle && pnpm test:rust",
    "format": "pnpm format:rust",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@shadcn/ui": "^0.0.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "oxlint": "^1.62.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.9.0"
}
